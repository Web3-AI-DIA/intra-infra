import { {{#each events}}{{name}} as {{name}}Entity{{#unless @last}}, {{/unless}}{{/each}} } from "../generated/schema"

{{#each events}}
export function handle{{name}}(event: {{name}}): void {
  let entity = new {{name}}Entity(event.transaction.hash.concatI32(event.logIndex.toI32()).toHexString())
  
  {{#each inputs}}
